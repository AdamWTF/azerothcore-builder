# Optional local MySQL connection settings for database check scripts.
#
# Copy this file to config/local/db.conf and fill in local values.
# config/local/db.conf is ignored by git.

# Use 127.0.0.1 for a local MySQL server or an SSH tunnel.
# Use <mysql-host> for a remote MySQL server reachable from this machine.
MYSQL_HOST="<mysql-host>"
MYSQL_PORT="3306"
MYSQL_USER="<mysql-user>"
MYSQL_PASSWORD="<mysql-password>"
