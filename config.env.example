# Local build paths
WORK_ROOT="$HOME/acore-manager"
SOURCE_DIR="$HOME/acore-manager/azerothcore"
BUILD_DIR="$HOME/acore-manager/azerothcore/build"
STAGING_DIR="$HOME/acore-manager/staging"

# AzerothCore source
AC_REPO="https://github.com/mod-playerbots/azerothcore-wotlk.git"
AC_BRANCH="Playerbot"

# Final install path on deployment server
REMOTE_HOST="<server-host>"
REMOTE_USER="<your-user>"
REMOTE_SERVER_ROOT="/opt/acore-manager"
REMOTE_INSTALL_DIR="/opt/acore-manager/server"
REMOTE_SOURCE_DIR="/opt/acore-manager/source"

# Build settings
BUILD_TYPE="RelWithDebInfo"
BUILD_THREADS="$(nproc)"
SCRIPTS_MODE="static"
MODULES_MODE="static"

# Compiler settings
# Leave empty to use system default, or set to gcc-14/g++-14 if needed.
C_COMPILER=""
CXX_COMPILER=""

# Service names on deployment server
AUTH_SERVICE="azerothcore-auth"
WORLD_SERVICE="azerothcore-world"

# Deploy behaviour
STOP_SERVICES_BEFORE_DEPLOY="true"
START_SERVICES_AFTER_DEPLOY="false"
BACKUP_REMOTE_ETC="true"
PRESERVE_REMOTE_CONFIGS="true"
