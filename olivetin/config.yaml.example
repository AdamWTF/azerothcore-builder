# Optional OliveTin configuration example for acore-manager.
#
# OliveTin is not required by acore-manager. This example is intended for a
# trusted LAN/VPN-only web UI. Do not expose OliveTin directly to the public
# internet.
#
# If acore-manager is installed somewhere other than /opt/acore-manager, adjust
# the command paths below.

pageTitle: acore-manager
showFooter: false
defaultPopupOnStart: execution-dialog
defaultIconForActions: "⚙️"
defaultIconForDirectories: "📁"
defaultIconForBack: "←"
showNavigateOnStartIcons: false

actions:
  - title: Status
    id: acore_status
    icon: "📊"
    shell: "/opt/acore-manager/bin/acore-manager status"

  - title: List releases
    id: acore_list_releases
    icon: "📦"
    shell: "/opt/acore-manager/bin/acore-manager list-releases"

  - title: View world logs
    id: acore_logs_world
    icon: "📜"
    shell: "/opt/acore-manager/bin/acore-manager logs-world"

  - title: View auth logs
    id: acore_logs_auth
    icon: "📜"
    shell: "/opt/acore-manager/bin/acore-manager logs-auth"

  - title: View recent errors
    id: acore_last_errors
    icon: "📜"
    shell: "/opt/acore-manager/bin/acore-manager last-errors"

  - title: Check database
    id: acore_db_check
    icon: "🗄️"
    shell: "/opt/acore-manager/bin/acore-manager db-check"

  - title: Restart worldserver
    id: acore_restart_world
    icon: "🔄"
    shell: "/opt/acore-manager/bin/acore-manager restart-world"

  - title: Restart authserver
    id: acore_restart_auth
    icon: "🔄"
    shell: "/opt/acore-manager/bin/acore-manager restart-auth"

  - title: Restart all AzerothCore services
    id: acore_restart_all
    icon: "🔄"
    shell: "/opt/acore-manager/bin/acore-manager restart"

  - title: Start services
    id: acore_start
    icon: "▶️"
    shell: "/opt/acore-manager/bin/acore-manager start"

  - title: Stop services - requires confirmation
    id: acore_stop
    icon: "⏹️"
    shell: "/opt/acore-manager/bin/acore-manager stop"
    arguments:
      - type: confirmation
        title: Confirm stopping authserver and worldserver.

  - title: Config backup
    id: acore_config_backup
    icon: "💾"
    shell: "/opt/acore-manager/bin/acore-manager config-backup"

  - title: Database backup - requires confirmation
    id: acore_db_backup
    icon: "💾"
    shell: "/opt/acore-manager/bin/acore-manager db-backup"
    arguments:
      - type: confirmation
        title: Confirm database backup. This may run for a while.

  - title: Build - requires confirmation
    id: acore_build
    icon: "🛠️"
    shell: "/opt/acore-manager/bin/acore-manager build"
    arguments:
      - type: confirmation
        title: Confirm starting an AzerothCore build. This can take a long time.

  - title: Create release
    id: acore_create_release
    icon: "📦"
    shell: "/opt/acore-manager/bin/acore-manager create-release"

  - title: Release latest - requires confirmation
    id: acore_release_latest
    icon: "🚀"
    shell: "/opt/acore-manager/bin/acore-manager release-latest"
    arguments:
      - type: confirmation
        title: Confirm full update/build/release/switch workflow.

  - title: Rollback release - requires confirmation
    id: acore_rollback
    icon: "↩️"
    shell: "/opt/acore-manager/bin/acore-manager rollback"
    arguments:
      - type: confirmation
        title: Confirm rollback to the previous release.

dashboards:
  - title: acore-manager
    contents:
      - title: Read-only and logs
        type: fieldset
        contents:
          - title: Status
          - title: List releases
          - title: View world logs
          - title: View auth logs
          - title: View recent errors
          - title: Check database

      - title: Runtime control
        type: fieldset
        contents:
          - title: Restart worldserver
          - title: Restart authserver
          - title: Restart all AzerothCore services
          - title: Start services
          - title: Stop services - requires confirmation

      - title: Maintenance
        type: fieldset
        contents:
          - title: Config backup
          - title: Database backup - requires confirmation
          - title: Build - requires confirmation
          - title: Create release
          - title: Release latest - requires confirmation
          - title: Rollback release - requires confirmation
