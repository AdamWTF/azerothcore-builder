# Optional sudoers example for running OliveTin as a non-root service user.
#
# The native OliveTin systemd service may run as root depending on how it is
# packaged or customized. If OliveTin runs as root, this sudoers file is not
# needed.
#
# To use a hardened non-root setup, run OliveTin as the "olivetin" user, install
# this file with visudo validation, and change OliveTin action commands to use:
#
#   sudo -n /opt/acore-manager/bin/acore-manager <command>
#
# This file intentionally does not grant NOPASSWD: ALL.

User_Alias ACORE_OLIVETIN = olivetin

Cmnd_Alias ACORE_MANAGER = \
  /opt/acore-manager/bin/acore-manager status, \
  /opt/acore-manager/bin/acore-manager list-releases, \
  /opt/acore-manager/bin/acore-manager logs-world, \
  /opt/acore-manager/bin/acore-manager logs-auth, \
  /opt/acore-manager/bin/acore-manager last-errors, \
  /opt/acore-manager/bin/acore-manager db-check, \
  /opt/acore-manager/bin/acore-manager restart-world, \
  /opt/acore-manager/bin/acore-manager restart-auth, \
  /opt/acore-manager/bin/acore-manager restart, \
  /opt/acore-manager/bin/acore-manager start, \
  /opt/acore-manager/bin/acore-manager stop, \
  /opt/acore-manager/bin/acore-manager config-backup, \
  /opt/acore-manager/bin/acore-manager db-backup, \
  /opt/acore-manager/bin/acore-manager build, \
  /opt/acore-manager/bin/acore-manager create-release, \
  /opt/acore-manager/bin/acore-manager release-latest, \
  /opt/acore-manager/bin/acore-manager rollback

ACORE_OLIVETIN ALL=(root) NOPASSWD: ACORE_MANAGER
